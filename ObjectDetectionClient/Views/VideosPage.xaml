<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:ObjectDetectionClient.Converters"
             x:Class="ObjectDetectionClient.Views.VideosPage"
             Title="视频列表">

    <ContentPage.Resources>
        <converters:StatusToColorConverter x:Key="StatusToColorConverter" />
    </ContentPage.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 顶部工具栏 -->
        <StackLayout Grid.Row="0" Padding="10" Spacing="10" BackgroundColor="#F5F5F5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Label Text="视频列表"
                       FontSize="24"
                       FontAttributes="Bold"
                       VerticalOptions="Center" />

                <!-- 刷新按钮 -->
                <Button Grid.Column="1"
                        Text="刷新"
                        Command="{Binding LoadVideosCommand}"
                        WidthRequest="80"
                        BackgroundColor="#4CAF50"
                        TextColor="White" />
            </Grid>
        </StackLayout>

        <!-- 视频列表 -->
        <CollectionView Grid.Row="1"
                       ItemsSource="{Binding Videos}"
                       SelectionMode="None">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border StrokeThickness="1"
                            Stroke="#E0E0E0"
                            StrokeShape="RoundRectangle 8"
                            Margin="10,5"
                            Padding="10"
                            BackgroundColor="White">
                        <Grid>
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer 
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.NavigateToVideoDetailCommand}"
                                    CommandParameter="{Binding .}" />
                            </Grid.GestureRecognizers>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Label Text="{Binding Filename}"
                                   FontSize="16"
                                   FontAttributes="Bold" />

                            <HorizontalStackLayout Grid.Row="1" Spacing="10">
                                <Label Text="{Binding Status}"
                                       FontSize="14">
                                    <Label.TextColor>
                                        <Binding Path="Status" Converter="{StaticResource StatusToColorConverter}" />
                                    </Label.TextColor>
                                </Label>

                                <Label Text="{Binding Id, StringFormat='ID: {0}'}"
                                       FontSize="12"
                                       TextColor="Gray" />
                            </HorizontalStackLayout>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>

            <CollectionView.Footer>
                <StackLayout HorizontalOptions="Center" Padding="20">
                    <Label Text="{Binding Videos.Count, StringFormat='共 {0} 个视频'}"
                           FontSize="14"
                           TextColor="Gray" />
                </StackLayout>
            </CollectionView.Footer>
        </CollectionView>

        <!-- 加载指示器 -->
        <ActivityIndicator Grid.RowSpan="2"
                           IsRunning="{Binding IsBusy}"
                           IsVisible="{Binding IsBusy}"
                           Color="#2196F3"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
    </Grid>
</ContentPage>